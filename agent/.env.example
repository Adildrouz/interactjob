# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Site ────────────────────────────────────────────────────────────────────────
SITE_URL=https://www.interactjob.ma

# ── LinkedIn ────────────────────────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=103873598

# ── Email ────────────────────────────────────────────────────────────────────────
GMAIL_USER=jobinteract@gmail.com
# App Password Google : myaccount.google.com → Sécurité → Mots de passe d'application
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Google Drive (optionnel) ────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GOOGLE_DRIVE_FOLDER_NAME=InteractJob-WhatsApp

# ── WhatsApp Cloud API (optionnel) ──────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_CHANNEL_ID=

# ── GitHub sync (requis sur Railway) ────────────────────────────────────────────
# Personal Access Token avec scope "repo" (write)
# github.com → Settings → Developer settings → Personal access tokens → Fine-grained
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Format: owner/repo  (le repo du site interactjob, pas un repo séparé)
GITHUB_REPO=adildrouz/interactjob

# ── Railway (défini automatiquement par Railway — ne pas modifier) ───────────────
PORT=3001
NODE_ENV=production
