{
  "functions": {
    "app/api/personality/report/generate/route.ts": { "memory": 3008 },
    "app/api/personality/report/email/route.ts":    { "memory": 3008 },
    "app/api/admin/linkedin/process/route.ts":      { "memory": 3008 },
    "app/api/cv/extract-text/route.ts":             { "memory": 3008 },
    "app/api/openai/route.ts":                      { "memory": 3008 },
    "app/api/deepseek/route.ts":                    { "memory": 3008 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
